{
    "name": "mwspace/e-shop",
    "description": "Perfect e-commerce package for the Laravel framework.",
    "keywords": [
        "laravel",
        "eshop",
        "e-shop",
        "ecommerce"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Aleksandr Ivanovitch",
            "email": "alex@mwspace.com"
        }
    ],
    "require": {
        "php": "^7.1.3",
        "ext-json": "*",
        "laravel/framework": "~5.8.0|^6.0|^7.0",
        "stripe/stripe-php": "^v7.14.0"
    },
    "require-dev": {
    },
    "autoload": {
        "psr-4": {
            "MwSpace\\Eshop\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php artisan config:clear"
        ],
        "post-update-cmd": [
            "@php artisan config:clear"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "MwSpace\\Eshop\\EshopServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
